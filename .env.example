# Throughline — Node server (server.js) configuration.
# Copy to .env and run:  node --env-file=.env server.js   (or: npm start, which
# reads the process environment). All values are optional — the defaults give a
# fully functional local v1 with no API spend.

# Where the single state document lives. Relative paths resolve against the repo
# root. On orange device, point this at a file inside a OneDrive shared folder
# so the dyad shares one project DB:
#   THROUGHLINE_DB=C:\Users\<you>\OneDrive - <org>\throughline\state.json
THROUGHLINE_DB=./data/state.json

# Folder-lens root (Epic E1). The real OneDrive tree Throughline reads/opens
# files from. Container "bound folders" are stored RELATIVE to this root, so
# they stay portable between Noah's and Natalia's boxes. Absolute, or relative
# to the repo root. Defaults to the folder that holds THROUGHLINE_DB.
# Read + open only — Throughline never writes or deletes inside this tree.
#   ONEDRIVE_ROOT=C:\Users\<you>\OneDrive - <org>
# ONEDRIVE_ROOT=./data

# Port / host for the local server.
PORT=8787
HOST=127.0.0.1

# AI ingestion provider for /api/atomize. One of:
#   heuristic — deterministic stub in shared/atomize.js. No key, no spend. Default.
#   anthropic — Anthropic Messages API (cloud / dev box). Needs ANTHROPIC_API_KEY.
#   cdsapi    — Optum's on-network metered endpoint. THE ORANGE-DEVICE PROVIDER:
#               the enterprise box can't reach Anthropic, but cdsapi needs no key
#               when on-network. See ~/GitHub_Repos/atom_sandbox for the same seam.
LLM_PROVIDER=heuristic

# --- anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6        # pins one model; else per-tier defaults

# --- cdsapi (orange device) ---
# LLM_PROVIDER=cdsapi
# CDSAPI_URL=http://cdsapi.ms.ds.uhc.com:8080/single_response   # default; override if needed
# LLM_MODEL=gpt-mini                        # pins one model; else per-tier: gpt-nano|gpt-mini|gpt-5.4

# Optional per-tier model overrides (apply to whichever provider is active):
# TIER_REASON_MODEL=...

# --- atomize experiment knobs (T20) ---
# Which model tier drafts the atomization. DEFAULT escalate = gpt-5.4 (T30,
# 2026-06-08: gpt-mini retired from the pipeline — it returned empty on real
# big dumps and 5.4 is faster + no-worse). reason = gpt-mini is now opt-in.
# ATOMIZE_TIER=escalate
# What happens when the model path fails (empty/garbled reply):
#   heuristic — fall back to the deterministic splitter (default)
#   escalate  — try once more on gpt-5.4, then the heuristic
#   error     — no fallback: the triage modal shows the failure; re-run to retry
# ATOMIZE_ON_FAIL=heuristic

# --- async ingestion jobs (T16, Node-only) ---
# Machine-local job/session store. Keep this OUTSIDE the shared OneDrive
# folder — jobs and chat sessions are one operator's work-in-progress and
# must not sync to the other dyad member. Default is fine.
# THROUGHLINE_JOBS=./data/jobs.json
# How many model jobs run at once (atomize + consult turns combined).
# THROUGHLINE_JOB_CONCURRENCY=3
